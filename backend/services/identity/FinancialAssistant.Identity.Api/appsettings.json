{
  "Identity": {
    "ServiceName": "financial-assistant-identity-service",
    "Storage": {
      "Provider": "Elasticsearch",
      "Environment": "dev",
      "SchemaVersion": 1,
      "InitialGeneration": 1,
      "Cleanup": {
        "DeletedAccountRetentionDays": 30,
        "RemovedCredentialRetentionDays": 30,
        "TerminalSessionRetentionDays": 30,
        "HardMaximumSessionDocumentDays": 90,
        "RemovedProviderLinkRetentionDays": 30
      }
    },
    "Authentication": {
      "RuntimeAdapter": "InMemoryDevelopment",
      "LookupHmacKey": "",
      "RefreshTokenHashKey": "",
      "AccessTokenSigningKey": "",
      "AccessTokenIssuer": "financial-assistant-identity",
      "AccessTokenAudience": "financial-assistant-clients",
      "AccessTokenLifetimeMinutes": 15,
      "RefreshTokenLifetimeDays": 30
    },
    "Providers": {
      "IdentifierHmacKey": "",
      "Google": {
        "Enabled": false,
        "ClientIds": [],
        "HostedDomain": null,
        "IssuedAtClockToleranceSeconds": 30,
        "ExpirationClockToleranceSeconds": 30
      },
      "Apple": {
        "Enabled": false,
        "ClientIds": [],
        "Issuer": "https://appleid.apple.com",
        "DiscoveryEndpoint": "https://appleid.apple.com/.well-known/openid-configuration",
        "ClockSkewSeconds": 60,
        "RequireNonce": true
      },
      "Phone": {
        "Enabled": false,
        "Adapter": "Disabled",
        "CodeLength": 6,
        "ChallengeLifetimeMinutes": 10,
        "ResendCooldownSeconds": 30,
        "MaximumAttempts": 5,
        "StartWindowMinutes": 60,
        "MaximumStartsPerPhone": 5,
        "MaximumStartsPerClient": 10
      }
    },
    "RateLimiting": {
      "Enabled": true,
      "Registration": {
        "PermitLimit": 5,
        "WindowSeconds": 600
      },
      "SignIn": {
        "PermitLimit": 10,
        "WindowSeconds": 300
      },
      "ProviderSignIn": {
        "PermitLimit": 10,
        "WindowSeconds": 300
      },
      "PhoneStart": {
        "PermitLimit": 5,
        "WindowSeconds": 60
      },
      "PhoneConfirm": {
        "PermitLimit": 20,
        "WindowSeconds": 300
      },
      "Session": {
        "PermitLimit": 60,
        "WindowSeconds": 60
      }
    },
    "Events": {
      "Mode": "InMemoryDevelopment",
      "Exchange": "fa.events",
      "ConnectionString": "",
      "UserIdHmacKey": "",
      "BatchSize": 25,
      "DispatchIntervalMilliseconds": 1000,
      "MaximumRetryDelaySeconds": 60
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
