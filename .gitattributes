# Normalize text files to LF in the repository.
* text=auto eol=lf

# Windows command scripts require CRLF for predictable execution.
*.bat text eol=crlf
*.cmd text eol=crlf

# Source and configuration files.
*.cs text diff=csharp
*.csproj text
*.props text
*.targets text
*.sln text
*.js text
*.jsx text
*.ts text
*.tsx text
*.json text
*.yml text
*.yaml text
*.md text
*.sh text eol=lf
*.ps1 text eol=lf
*.xml text

# Binary assets and archives.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.7z binary
*.dll binary
*.exe binary
*.pdb binary
*.nupkg binary
*.snupkg binary
*.apk binary
*.aab binary
*.ipa binary
