root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{cs,csx}]
indent_size = 4
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

[*.{js,jsx,ts,tsx,mjs,cjs,json,yml,yaml,css,scss,md}]
indent_size = 2

[*.{csproj,props,targets,xml}]
indent_size = 2

[*.{sh,bash}]
indent_size = 2
end_of_line = lf

[*.{bat,cmd}]
indent_size = 2
end_of_line = crlf

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false

# Keep the PoC rules practical. Stricter style and analyzer rules can be added
# incrementally without changing line endings or indentation conventions.
