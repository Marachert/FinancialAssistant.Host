{
  "Identity": {
    "ServiceName": "financial-assistant-identity-service",
    "Storage": {
      "Provider": "Elasticsearch",
      "Environment": "dev",
      "SchemaVersion": 1,
      "InitialGeneration": 1,
      "Cleanup": {
        "DeletedAccountRetentionDays": 30,
        "RemovedCredentialRetentionDays": 30,
        "TerminalSessionRetentionDays": 30,
        "HardMaximumSessionDocumentDays": 90,
        "RemovedProviderLinkRetentionDays": 30
      }
    },
    "Authentication": {
      "RuntimeAdapter": "InMemoryDevelopment",
      "LookupHmacKey": "",
      "RefreshTokenHashKey": "",
      "AccessTokenSigningKey": "",
      "AccessTokenIssuer": "financial-assistant-identity",
      "AccessTokenAudience": "financial-assistant-clients",
      "AccessTokenLifetimeMinutes": 15,
      "RefreshTokenLifetimeDays": 30
    },
    "Providers": {
      "IdentifierHmacKey": "",
      "Google": {
        "Enabled": false,
        "ClientIds": [],
        "HostedDomain": null,
        "IssuedAtClockToleranceSeconds": 30,
        "ExpirationClockToleranceSeconds": 30
      }
    },
    "Events": {
      "Mode": "InMemoryDevelopment",
      "Exchange": "fa.events",
      "ConnectionString": "",
      "UserIdHmacKey": "",
      "BatchSize": 25,
      "DispatchIntervalMilliseconds": 1000,
      "MaximumRetryDelaySeconds": 60
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
