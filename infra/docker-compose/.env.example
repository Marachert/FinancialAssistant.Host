# Financial Assistant local infrastructure
# Development-only values. Do not use production configuration here.

FA_ENVIRONMENT=local
ASPNETCORE_ENVIRONMENT=Development

# Elasticsearch
ELASTIC_VERSION=8.15.3
ELASTICSEARCH_HOST_PORT=9200
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_LOCAL_URL=http://localhost:9200
ELASTICSEARCH_JAVA_OPTS=-Xms512m -Xmx512m

# RabbitMQ
RABBITMQ_VERSION=3.13-management
RABBITMQ_HOST=rabbitmq
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_DEFAULT_USER=fa_local
RABBITMQ_DEFAULT_PASS=fa_local_dev_only
RABBITMQ_VHOST=fa-local
RABBITMQ_URL=amqp://fa_local:fa_local_dev_only@rabbitmq:5672/fa-local
RABBITMQ_LOCAL_MANAGEMENT_URL=http://localhost:15672

# Redis
REDIS_VERSION=7-alpine
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_HOST_PORT=6379
REDIS_CONNECTION=redis:6379
REDIS_LOCAL_URL=redis://localhost:6379
REDIS_DOCKER_URL=redis://redis:6379

# MinIO
MINIO_VERSION=latest
MINIO_HOST=minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=fa_local_minio
MINIO_ROOT_PASSWORD=fa_local_minio_dev_only
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_CONSOLE_URL=http://localhost:9001
MINIO_BUCKET_RECEIPTS=fa-local-receipts
MINIO_BUCKET_EXPORTS=fa-local-exports
MINIO_REGION=local

# Monitoring
PROMETHEUS_VERSION=latest
PROMETHEUS_PORT=9090
PROMETHEUS_URL=http://prometheus:9090
PROMETHEUS_LOCAL_URL=http://localhost:9090

GRAFANA_VERSION=latest
GRAFANA_PORT=3000
GRAFANA_LOCAL_URL=http://localhost:3000
GRAFANA_ADMIN_USER=fa_local_admin
GRAFANA_ADMIN_PASSWORD=development_only_value

OTEL_SERVICE_NAME=financial-assistant-local
