# Read-only Git commands

prefix_rule(
    pattern = ["git", ["status", "diff", "fetch", "branch"]],
    decision = "allow",
    justification = "Required for repository state discovery.",
)

prefix_rule(
    pattern = ["git", ["checkout", "switch", "add", "commit"]],
    decision = "allow",
    justification = "Required for work on codex delivery branches.",
)

# Pushes are allowed to origin, but main and force pushes are blocked below.

prefix_rule(
    pattern = ["git", "push", "origin"],
    decision = "allow",
    justification = "Required to publish codex delivery branches.",
)

prefix_rule(
    pattern = ["git", "push", "origin", "main"],
    decision = "forbidden",
    justification = "Push through a pull request instead of pushing directly to main.",
)

prefix_rule(
    pattern = ["git", "push", "--force"],
    decision = "forbidden",
    justification = "Force pushes are prohibited. Push a normal follow-up commit instead.",
)

prefix_rule(
    pattern = ["git", "push", "-f"],
    decision = "forbidden",
    justification = "Force pushes are prohibited. Push a normal follow-up commit instead.",
)

prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "forbidden",
    justification = "Do not discard repository changes. Restore individual files safely.",
)

prefix_rule(
    pattern = ["git", "clean", "-fdx"],
    decision = "forbidden",
    justification = "Do not delete untracked workspace content recursively.",
)

# GitHub CLI

prefix_rule(
    pattern = ["gh", "auth", "status"],
    decision = "allow",
    justification = "Required to verify GitHub authentication.",
)

prefix_rule(
    pattern = ["gh", "pr", ["view", "list", "checks", "create", "comment", "review", "merge"]],
    decision = "allow",
    justification = "Required for the guarded pull-request delivery workflow.",
)

prefix_rule(
    pattern = ["gh", "repo", "delete"],
    decision = "forbidden",
    justification = "Repository deletion is never part of the delivery workflow.",
)

# Build and test

prefix_rule(
    pattern = ["dotnet", ["restore", "build", "test", "format"]],
    decision = "allow",
    justification = "Required for backend verification.",
)

prefix_rule(
    pattern = ["docker", "compose", "config"],
    decision = "allow",
    justification = "Required for non-destructive Compose validation.",
)

# Project delivery wrappers

prefix_rule(
    pattern = ["pwsh", "tools/delivery/jira.ps1"],
    decision = "allow",
    justification = "Required for Jira delivery-state updates.",
)

prefix_rule(
    pattern = ["pwsh", "tools/delivery/confluence.ps1"],
    decision = "allow",
    justification = "Required for Confluence evidence updates.",
)